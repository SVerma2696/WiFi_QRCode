# OS generated files (Prevents Mac and Windows junk files from uploading)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files (Prevents VS Code or other editor settings from uploading)
.idea/
.vscode/
*.suo
.ntvs
*.njsproj
*.sln
*.sw?

# Node.js tooling (used for the Vitest unit test suite -- the app itself has no build step
# or dependencies, but `npm install` for testing generates these locally)
node_modules/
package-lock.json
.env

# Test/coverage output, in case coverage reporting is added to the Vitest config later
coverage/
*.log